---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import SEOHead from '../components/SEOHead.astro';
import DailyCard from '../components/DailyCard';
import { getCollection } from 'astro:content';

const dailyCards = await getCollection('daily');
const sorted = dailyCards
  .map((c) => c.data)
  .sort((a, b) => a.order - b.order);
---

<BaseLayout class="home">
  <SEOHead
    slot="head"
    title="Bravo Zulu | Daily Naval History"
    description="One naval history fact per day. Tap to learn. Share to brag. Come back tomorrow for the next one."
  />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "Bravo Zulu",
    "url": "https://brvzulu.com",
    "description": "Daily naval history stories and in-depth articles about the world's warships. Each story starts with a surprising fact.",
    "publisher": {
      "@type": "Organization",
      "name": "Bravo Zulu",
      "url": "https://brvzulu.com"
    }
  })} />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "FAQPage",
    "mainEntity": [
      {
        "@type": "Question",
        "name": "What happened to USS New Orleans in 1942?",
        "acceptedAnswer": { "@type": "Answer", "text": "USS New Orleans was hit by a torpedo at the Battle of Tassafaronga, blowing off 150 feet of bow and killing 182 sailors. The crew built a temporary bow from coconut logs at Tulagi and sailed backwards 1,800 miles to Sydney. The severed bow was found at 675 meters in 2025." }
      },
      {
        "@type": "Question",
        "name": "What was the Battle of Penang 1914?",
        "acceptedAnswer": { "@type": "Answer", "text": "SMS Emden entered Penang harbor with a fake fourth funnel, torpedoed the Russian cruiser Zhemchug, and killed 82 crew. The Russian captain was at the Eastern & Oriental Hotel. He was sentenced to 3.5 years." }
      },
      {
        "@type": "Question",
        "name": "Did Prinz Eugen survive nuclear bombs?",
        "acceptedAnswer": { "@type": "Answer", "text": "Yes. Prinz Eugen survived both atomic tests at Bikini Atoll in 1946 but became too radioactive to repair. She capsized from a small leak at Kwajalein. Her stern still sticks out of the water." }
      },
      {
        "@type": "Question",
        "name": "What does Bravo Zulu mean in the Navy?",
        "acceptedAnswer": { "@type": "Answer", "text": "Bravo Zulu (BZ) is the NATO signal flag code meaning 'well done.' It is the highest compliment one warship can signal to another." }
      }
    ]
  })} />

  <Navigation active="daily" />

  <main class="home-main">
    <DailyCard client:idle cards={sorted} />
  </main>
</BaseLayout>

<style is:global>
  body.home {
    overflow-y: auto;
  }

  .home-main {
    padding-top: calc(var(--nav-height) + var(--banner-offset));
    min-height: 100dvh;
  }


  /* Daily card container */
  .daily-container {
    max-width: 600px;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 3rem;
  }

  .daily-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 1.25rem;
  }

  .daily-day {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--text-primary);
  }

  .daily-streak {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--accent);
    background: rgba(59, 130, 246, 0.1);
    padding: 0.2rem 0.625rem;
    border-radius: 100px;
  }

  /* Today's card */
  .daily-card-wrap {
    cursor: pointer;
    user-select: none;
    -webkit-user-select: none;
  }

  .daily-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    min-height: 380px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, #0c1929 0%, #1a1a2e 50%, #16213e 100%);
  }

  @media (min-width: 640px) {
    .daily-card {
      min-height: 440px;
    }
  }

  .daily-card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
  }

  .daily-card-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 2rem 1.5rem;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .daily-year {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.45);
    background: rgba(255, 255, 255, 0.08);
    padding: 0.2rem 0.625rem;
    border-radius: 100px;
  }

  .daily-hook {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 4vw, 1.75rem);
    font-weight: 700;
    line-height: 1.3;
    color: #fff;
    max-width: 95%;
  }

  .daily-ship {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 500;
  }

  .daily-tap {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: rgba(255, 255, 255, 0.3);
    margin-top: 0.5rem;
    animation: daily-pulse 2s ease-in-out infinite;
  }

  @keyframes daily-pulse {
    0%, 100% { opacity: 0.3; }
    50% { opacity: 0.6; }
  }

  /* Revealed state */
  .daily-revealed {
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .daily-reveal-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.9);
  }

  .daily-actions {
    display: flex;
    gap: 0.5rem;
  }

  .daily-btn {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    padding: 0.5rem 1.25rem;
    border-radius: 100px;
    border: none;
    cursor: pointer;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .daily-btn:hover { opacity: 0.85; }

  .daily-btn--primary {
    color: #fff;
    background: var(--accent);
  }

  .daily-btn--share {
    color: rgba(255, 255, 255, 0.6);
    background: none;
    border: 1px solid rgba(255, 255, 255, 0.15);
  }

  .daily-btn--share:hover {
    color: #fff;
    border-color: rgba(255, 255, 255, 0.3);
  }

  /* Stats */
  .daily-stats {
    display: flex;
    justify-content: space-between;
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--text-muted);
    margin-top: 1rem;
    padding: 0 0.25rem;
  }

  /* Archive */
  .daily-archive {
    margin-top: 2.5rem;
  }

  .daily-archive-title {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--text-muted);
    margin-bottom: 1rem;
  }

  .daily-archive-grid {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .daily-archive-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1rem 1.25rem;
    cursor: pointer;
    transition: border-color 0.2s;
  }

  .daily-archive-card:hover {
    border-color: var(--text-muted);
  }

  .daily-archive-year {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .daily-archive-hook {
    font-family: var(--font-display);
    font-size: 0.9375rem;
    line-height: 1.3;
    color: var(--text-primary);
    margin: 0.375rem 0;
  }

  .daily-archive-ship {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    color: var(--text-muted);
  }

  .daily-browse-all {
    display: block;
    text-align: center;
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--accent);
    margin-top: 1.25rem;
    text-decoration: none;
  }

  .daily-browse-all:hover {
    text-decoration: underline;
  }
</style>
