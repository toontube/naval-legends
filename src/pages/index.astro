---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import SEOHead from '../components/SEOHead.astro';
import SwipeCards from '../components/SwipeCards';
import { getCollection } from 'astro:content';

const dailyCards = await getCollection('daily');
const sorted = dailyCards
  .map((c) => c.data)
  .sort((a, b) => a.order - b.order);
---

<BaseLayout class="home">
  <SEOHead
    slot="head"
    title="Bravo Zulu | Daily Naval History Stories"
    description="Swipe through daily naval history stories. Short hooks, deep articles. The world's warships, one story at a time."
  />

  <Navigation active="daily" />

  <main class="home-main">
    <SwipeCards client:idle cards={sorted} />
  </main>
</BaseLayout>

<style>
  .home-main {
    position: fixed;
    top: var(--nav-height);
    left: 0;
    right: 0;
    bottom: 0;
    overflow: hidden;
  }
</style>

<style is:global>
  body.home {
    overflow: hidden;
  }

  .swipe-container {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .swipe-card {
    position: absolute;
    width: 100%;
    height: 100%;
    touch-action: none;
    user-select: none;
    -webkit-user-select: none;
  }

  .swipe-card--behind {
    transform: scale(0.95);
    filter: brightness(0.7);
  }

  .card {
    position: relative;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .card-bg {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0.3;
  }

  .card-content {
    position: relative;
    z-index: 1;
    text-align: center;
    padding: 1.5rem 1.25rem 4rem;
    max-width: 600px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  @media (min-width: 640px) {
    .card-content {
      padding: 2rem 2rem 4rem;
      gap: 1rem;
    }
  }

  .card-year {
    font-family: var(--font-ui);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--text-muted);
    background: rgba(255, 255, 255, 0.08);
    padding: 0.2rem 0.625rem;
    border-radius: 100px;
  }

  @media (min-width: 640px) {
    .card-year {
      font-size: 0.8125rem;
      padding: 0.25rem 0.75rem;
    }
  }

  .card-hook {
    font-family: var(--font-display);
    font-size: clamp(1.25rem, 4vw, 2.25rem);
    font-weight: 700;
    line-height: 1.25;
    color: #fff;
    max-width: 90%;
  }

  @media (max-width: 380px) {
    .card-hook {
      font-size: 1.125rem;
      line-height: 1.3;
    }
  }

  .card-ship {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--text-secondary);
    font-weight: 500;
  }

  @media (min-width: 640px) {
    .card-ship {
      font-size: 0.9375rem;
    }
  }

  .card-action {
    margin-top: 0.5rem;
  }

  @media (min-width: 640px) {
    .card-action {
      margin-top: 1rem;
    }
  }

  .card-btn {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 500;
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.25);
    padding: 0.625rem 1.5rem;
    border-radius: 100px;
    transition: all 0.2s;
    text-decoration: none;
  }

  .card-btn:hover {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.4);
  }

  .card-btn--soon {
    opacity: 0.4;
    cursor: default;
    border-color: rgba(255, 255, 255, 0.1);
  }

  .card-btn--soon:hover {
    background: transparent;
    border-color: rgba(255, 255, 255, 0.1);
  }

  .swipe-arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    font-size: 2.5rem;
    color: rgba(255, 255, 255, 0.4);
    z-index: 10;
    padding: 0.5rem;
    transition: color 0.2s;
    line-height: 1;
  }

  .swipe-arrow:hover:not(:disabled) {
    color: rgba(255, 255, 255, 0.8);
  }

  .swipe-arrow--left {
    left: 0.75rem;
  }

  .swipe-arrow--right {
    right: 0.75rem;
  }

  /* Hide arrows on mobile */
  @media (max-width: 768px) {
    .swipe-arrow {
      display: none;
    }
  }

  .swipe-counter {
    position: absolute;
    bottom: 0.75rem;
    left: 50%;
    transform: translateX(-50%);
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    color: var(--text-muted);
    z-index: 10;
    letter-spacing: 0.05em;
  }

  @media (min-width: 640px) {
    .swipe-counter {
      bottom: 1.5rem;
      font-size: 0.75rem;
    }
  }

  .swipe-end {
    text-align: center;
    padding: 2rem 1.5rem;
    max-width: 440px;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
  }

  .swipe-end-label {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .swipe-end-heading {
    font-family: var(--font-display);
    font-size: clamp(1.375rem, 4vw, 1.75rem);
    color: #fff;
    line-height: 1.25;
  }

  .swipe-end-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .swipe-end-btn {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: #fff;
    background: var(--accent);
    padding: 0.75rem 1.75rem;
    border-radius: 100px;
    text-decoration: none;
    margin-top: 0.5rem;
    transition: opacity 0.2s;
  }

  .swipe-end-btn:hover {
    opacity: 0.9;
  }

  .swipe-end-restart {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--text-muted);
    text-decoration: underline;
    text-underline-offset: 2px;
    margin-top: 0.25rem;
  }

  .swipe-end-restart:hover {
    color: var(--text-secondary);
  }
</style>
