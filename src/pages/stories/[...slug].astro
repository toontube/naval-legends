---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map((story) => ({
    params: { slug: story.data.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await render(story);

// Tag-based story recommendations
const allStories = await getCollection('stories');
const currentTags = new Set(story.data.tags);
const otherStories = allStories
  .filter((s) => s.data.slug !== story.data.slug)
  .map((s) => ({
    ...s,
    tagOverlap: s.data.tags.filter((t: string) => currentTags.has(t)).length,
  }))
  .sort((a, b) => {
    // Prefer tag overlap, then stories with images, then random
    if (b.tagOverlap !== a.tagOverlap) return b.tagOverlap - a.tagOverlap;
    const aImg = a.data.image ? 1 : 0;
    const bImg = b.data.image ? 1 : 0;
    if (bImg !== aImg) return bImg - aImg;
    return Math.random() - 0.5;
  })
  .slice(0, 3);

const dateStr = story.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});

const ksUrl = 'https://www.kickstarter.com/projects/mozuma/naval-legends-cruisers?ref=bz-article';
const ksStickyUrl = 'https://www.kickstarter.com/projects/mozuma/naval-legends-cruisers?ref=bz-sticky';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`${story.data.title} | Bravo Zulu`}
    description={story.data.summary}
    image={`/og/${story.data.slug}.png`}
    type="article"
    keywords={story.data.tags.join(', ') + ', naval history, warships, bravo zulu'}
  />
  <script slot="head" type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": story.data.title,
    "description": story.data.summary,
    "image": story.data.image ? `https://brvzulu.com${story.data.image}` : undefined,
    "datePublished": story.data.date.toISOString(),
    "author": { "@type": "Organization", "name": "Bravo Zulu" },
    "publisher": { "@type": "Organization", "name": "Bravo Zulu", "url": "https://brvzulu.com" },
    "mainEntityOfPage": `https://brvzulu.com/stories/${story.data.slug}`,
  })} />

  <Navigation active="stories" showThemeToggle />

  <main class="article-page">
    <a href="/" class="article-back">&larr; Back to Daily</a>

    {story.data.image && (
      <figure class="article-hero">
        <img src={story.data.image} alt={story.data.title} />
      </figure>
    )}

    <header class="article-header">
      <h1 class="article-title">{story.data.title}</h1>
      <p class="article-summary">{story.data.summary}</p>
      <div class="article-meta">
        <time datetime={story.data.date.toISOString().split('T')[0]}>{dateStr}</time>
        <span>{story.data.readingTime} min read</span>
      </div>
    </header>

    <article class="prose" id="article-body">
      <Content />
    </article>

    <!-- 50% scroll nudge -->
    <div class="scroll-nudge" id="scroll-nudge">
      <p>Enjoying this? <a href="#article-subscribe" class="scroll-nudge-link" id="scroll-nudge-link">Get a free foil card &rarr;</a></p>
    </div>

    <div class="article-tags">
      {story.data.tags.map((tag: string) => (
        <span class="article-tag">{tag}</span>
      ))}
    </div>

    <!-- KS inline card -->
    <a href={ksUrl} target="_blank" rel="noopener" class="article-ks-inline" id="article-ks-inline">
      <img src="/images/cruisers-book.png" alt="Naval Legends: Cruisers" class="article-ks-img" />
      <div class="article-ks-body">
        <span class="article-ks-label">Coming to Kickstarter</span>
        <h3 class="article-ks-title">Naval Legends: Cruisers</h3>
        <p class="article-ks-desc">170 years of navies trying to cheat physics. The book behind Bravo Zulu. Get notified at launch.</p>
      </div>
    </a>

    <!-- Read next — tag-matched stories with images -->
    {otherStories.length > 0 && (
      <section class="read-next">
        <h2 class="read-next-title">Read next</h2>
        <div class="read-next-grid">
          {otherStories.map((s) => (
            <a href={`/stories/${s.data.slug}`} class="read-next-card" data-tags={s.tagOverlap}>
              {s.data.image && (
                <img src={s.data.image} alt={s.data.title} class="read-next-img" loading="lazy" />
              )}
              <div class="read-next-card-body">
                <h3>{s.data.title}</h3>
                <p>{s.data.summary}</p>
                {s.tagOverlap > 0 && (
                  <div class="read-next-tags">
                    {s.data.tags.filter((t: string) => currentTags.has(t)).map((t: string) => (
                      <span class="read-next-tag-match">{t}</span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    <!-- Subscribe with foil card incentive -->
    <div class="article-subscribe" id="article-subscribe">
      <span class="subscribe-badge">FREE</span>
      <h3 class="subscribe-headline">Get a free foil card</h3>
      <p class="subscribe-text">Subscribe and we'll send you a free foil collector card from the Naval Legends: Cruisers series. Plus new stories when they drop.</p>
      <form class="article-subscribe-form" id="article-subscribe-form">
        <input
          type="email"
          name="email"
          placeholder="your@email.com"
          required
          class="article-subscribe-input"
          id="article-subscribe-email"
        />
        <button type="submit" class="article-subscribe-btn" id="article-subscribe-btn">Claim my card</button>
      </form>
      <p class="article-subscribe-status" id="article-subscribe-status"></p>
      <p class="subscribe-fine">No spam. Unsubscribe anytime.</p>
    </div>
  </main>

  <!-- Sticky mobile CTA -->
  <div class="sticky-cta" id="sticky-cta" aria-hidden="true">
    <a href={ksStickyUrl} target="_blank" rel="noopener" class="sticky-cta-btn" id="sticky-cta-btn">
      Get Notified — Cruisers Book on Kickstarter
    </a>
    <button class="sticky-cta-close" id="sticky-cta-close" aria-label="Dismiss">&times;</button>
  </div>

  <Footer />
</BaseLayout>

<style>
  .article-page {
    padding-top: calc(var(--nav-height) + var(--banner-offset) + 2rem);
    padding-bottom: 3rem;
    max-width: 720px;
    margin: 0 auto;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }

  .article-back {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    transition: color 0.2s;
  }

  .article-back:hover {
    color: var(--text-primary);
  }

  .article-hero {
    margin: 0 -1.25rem 2rem;
    border-radius: 0;
    overflow: hidden;
    max-height: 400px;
  }

  @media (min-width: 640px) {
    .article-hero {
      margin: 0 0 2rem;
      border-radius: 8px;
    }
  }

  .article-hero img {
    width: 100%;
    height: 100%;
    max-height: 400px;
    object-fit: cover;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    line-height: 1.2;
    margin-bottom: 0.75rem;
  }

  .article-summary {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.5;
    color: var(--text-secondary);
    margin-bottom: 0.75rem;
  }

  .article-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .article-meta span::before {
    content: '·';
    margin-right: 1rem;
  }

  /* Scroll nudge — hidden until 50% scroll */
  .scroll-nudge {
    display: none;
    text-align: center;
    padding: 0.75rem 0;
    margin-top: 1rem;
  }

  .scroll-nudge.visible {
    display: block;
  }

  .scroll-nudge p {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--text-muted);
  }

  .scroll-nudge-link {
    color: #22c55e;
    font-weight: 500;
    text-decoration: none;
  }

  .scroll-nudge-link:hover {
    text-decoration: underline;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .article-tag {
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--bg-surface);
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    text-transform: lowercase;
  }

  /* KS inline card */
  .article-ks-inline {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    margin-top: 2rem;
    padding: 1.25rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    transition: border-color 0.2s;
    text-decoration: none;
  }

  .article-ks-inline:hover {
    border-color: var(--accent);
  }

  .article-ks-img {
    width: 80px;
    height: auto;
    border-radius: 4px;
    flex-shrink: 0;
    object-fit: cover;
  }

  .article-ks-label {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 600;
    color: #22c55e;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.25rem;
  }

  .article-ks-title {
    font-size: 1rem;
    line-height: 1.3;
    margin-bottom: 0.25rem;
    color: var(--text-primary);
  }

  .article-ks-desc {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  @media (max-width: 480px) {
    .article-ks-img {
      width: 64px;
    }
  }

  /* Read next */
  .read-next {
    margin-top: 2rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .read-next-title {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .read-next-grid {
    display: grid;
    gap: 1rem;
    grid-template-columns: 1fr;
  }

  @media (min-width: 640px) {
    .read-next-grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .read-next-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    overflow: hidden;
    transition: border-color 0.2s;
  }

  .read-next-card:hover {
    border-color: var(--text-muted);
  }

  .read-next-img {
    display: block;
    width: 100%;
    height: 140px;
    object-fit: cover;
    background: var(--bg-surface);
    color: transparent;
    font-size: 0;
  }

  .read-next-card-body {
    padding: 1rem 1.25rem 1.25rem;
  }

  .read-next-card-body h3 {
    font-size: 0.9375rem;
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }

  .read-next-card-body p {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.4;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .read-next-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.375rem;
    margin-top: 0.5rem;
  }

  .read-next-tag-match {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    color: var(--accent);
    background: var(--accent-dim);
    padding: 0.125rem 0.5rem;
    border-radius: 100px;
  }

  /* Subscribe — foil card incentive */
  .article-subscribe {
    margin-top: 2.5rem;
    padding: 1.75rem;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-left: 3px solid #22c55e;
    border-radius: 8px;
    text-align: center;
  }

  .subscribe-badge {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    font-weight: 700;
    color: #fff;
    background: #22c55e;
    padding: 0.15rem 0.5rem;
    border-radius: 100px;
    letter-spacing: 0.03em;
    margin-bottom: 0.5rem;
  }

  .subscribe-headline {
    font-family: var(--font-display);
    font-size: 1.25rem;
    font-weight: 700;
    margin-bottom: 0.5rem;
  }

  .subscribe-text {
    font-family: var(--font-body);
    font-size: 0.9375rem;
    color: var(--text-secondary);
    line-height: 1.5;
    margin-bottom: 1rem;
    max-width: 440px;
    margin-left: auto;
    margin-right: auto;
  }

  .article-subscribe-form {
    display: flex;
    gap: 0.5rem;
    max-width: 360px;
    margin: 0 auto;
  }

  .article-subscribe-input {
    flex: 1;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    color: var(--text-primary);
    background: var(--bg-surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.625rem 0.875rem;
    min-width: 0;
  }

  .article-subscribe-input::placeholder {
    color: var(--text-muted);
  }

  .article-subscribe-input:focus {
    outline: none;
    border-color: #22c55e;
  }

  .article-subscribe-btn {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    font-weight: 500;
    color: #fff;
    background: #22c55e;
    border: none;
    border-radius: 6px;
    padding: 0.625rem 1rem;
    white-space: nowrap;
    transition: opacity 0.2s;
  }

  .article-subscribe-btn:hover {
    opacity: 0.9;
  }

  .article-subscribe-status {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    margin-top: 0.5rem;
    min-height: 1.25rem;
  }

  .subscribe-fine {
    font-family: var(--font-ui);
    font-size: 0.6875rem;
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  /* Sticky mobile CTA */
  .sticky-cta {
    position: fixed;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 99;
    padding: 0.75rem 1.25rem;
    padding-bottom: max(0.75rem, env(safe-area-inset-bottom));
    background: var(--bg-card);
    border-top: 1px solid var(--border);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    transform: translateY(100%);
    opacity: 0;
    transition: transform 0.3s ease, opacity 0.3s ease;
    display: none;
  }

  .sticky-cta.visible {
    transform: translateY(0);
    opacity: 1;
  }

  @media (max-width: 640px) {
    .sticky-cta {
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }
  }

  .sticky-cta-btn {
    display: block;
    flex: 1;
    text-align: center;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 500;
    color: #fff;
    background: var(--accent);
    padding: 0.75rem;
    border-radius: 8px;
    text-decoration: none;
    transition: opacity 0.2s;
  }

  .sticky-cta-btn:hover {
    opacity: 0.85;
  }

  .sticky-cta-close {
    font-size: 1.25rem;
    color: var(--text-muted);
    background: none;
    border: none;
    padding: 0.25rem 0.5rem;
    line-height: 1;
    flex-shrink: 0;
  }

  .sticky-cta-close:hover {
    color: var(--text-primary);
  }
</style>

<script>
  // Scroll reveal — fade in paragraphs as they enter viewport
  const revealElements = document.querySelectorAll('.prose > p, .prose > h2, .prose > h3, .prose > figure, .prose > blockquote');

  // Reveal first 3 elements immediately (above fold)
  revealElements.forEach((el, i) => {
    if (i < 3) el.classList.add('revealed');
  });

  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach((entry) => {
      if (entry.isIntersecting) {
        entry.target.classList.add('revealed');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { rootMargin: '0px 0px -60px 0px', threshold: 0.1 });

  revealElements.forEach((el, i) => {
    if (i >= 3) revealObserver.observe(el);
  });

  // Pretext CLS prevention
  async function measureArticle() {
    try {
      const { prepare, layout } = await import('@chenglou/pretext');
      await document.fonts.ready;
      const el = document.getElementById('article-body');
      if (!el) return;
      const text = el.textContent || '';
      const prepared = prepare(text, '18px Lora');
      const { height } = layout(prepared, el.offsetWidth, 31.5);
      el.style.minHeight = `${height}px`;
    } catch {
      // Pretext is optional
    }
  }
  measureArticle();

  // Track article scroll depth + trigger nudge + sticky CTA
  const slug = window.location.pathname.split('/').filter(Boolean).pop();
  const milestones = new Set<number>();
  const scrollNudge = document.getElementById('scroll-nudge');
  const stickyCTA = document.getElementById('sticky-cta');
  let stickyDismissed = sessionStorage.getItem('bz-sticky-dismissed') === '1';

  function checkScroll() {
    const scrolled = window.scrollY;
    const total = document.body.scrollHeight - window.innerHeight;
    if (total <= 0) return;
    const pct = Math.round((scrolled / total) * 100);

    for (const m of [25, 50, 75, 100]) {
      if (pct >= m && !milestones.has(m)) {
        milestones.add(m);
        (window as any).gtag?.('event', 'article_scroll', {
          article_slug: slug,
          scroll_depth: m,
        });

        // Show nudge at 50%
        if (m === 50 && scrollNudge && !localStorage.getItem('bz-subscribed')) {
          scrollNudge.classList.add('visible');
          (window as any).gtag?.('event', 'subscribe_nudge_visible', { article_slug: slug });
        }
      }
    }

    // Sticky CTA: show after 25%, hide near KS inline or subscribe
    if (milestones.has(25) && stickyCTA && !stickyDismissed) {
      stickyCTA.classList.add('visible');
    }
  }
  window.addEventListener('scroll', checkScroll, { passive: true });

  // Hide sticky CTA when KS inline or subscribe section is in viewport
  const ksInline = document.getElementById('article-ks-inline');
  const subBlock = document.getElementById('article-subscribe');

  if (stickyCTA && (ksInline || subBlock)) {
    const hideObserver = new IntersectionObserver((entries) => {
      entries.forEach((e) => {
        if (e.isIntersecting) {
          stickyCTA.classList.remove('visible');
        } else if (milestones.has(25) && !stickyDismissed) {
          stickyCTA.classList.add('visible');
        }
      });
    }, { threshold: 0.1 });

    if (ksInline) hideObserver.observe(ksInline);
    if (subBlock) hideObserver.observe(subBlock);
  }

  // Dismiss sticky CTA
  document.getElementById('sticky-cta-close')?.addEventListener('click', () => {
    stickyCTA?.classList.remove('visible');
    stickyDismissed = true;
    sessionStorage.setItem('bz-sticky-dismissed', '1');
  });

  // Track sticky CTA click
  document.getElementById('sticky-cta-btn')?.addEventListener('click', () => {
    (window as any).gtag?.('event', 'click_ks_sticky', { from_slug: slug });
  });

  // Track nudge link click
  document.getElementById('scroll-nudge-link')?.addEventListener('click', () => {
    (window as any).gtag?.('event', 'subscribe_nudge_click', { article_slug: slug });
  });

  // Track source link clicks
  document.querySelectorAll('.prose a[href^="http"]').forEach((link) => {
    link.addEventListener('click', () => {
      (window as any).gtag?.('event', 'click_source_link', {
        article_slug: slug,
        link_url: (link as HTMLAnchorElement).href,
        link_text: link.textContent?.trim(),
      });
    });
  });

  // Track KS inline card click
  document.getElementById('article-ks-inline')?.addEventListener('click', () => {
    (window as any).gtag?.('event', 'click_ks_inline', { from_slug: slug });
  });

  // Track "Read next" clicks
  document.querySelectorAll('.read-next-card').forEach((card) => {
    card.addEventListener('click', () => {
      (window as any).gtag?.('event', 'click_read_next', {
        from_slug: slug,
        to_slug: (card as HTMLAnchorElement).href.split('/').filter(Boolean).pop(),
        shared_tags: parseInt(card.getAttribute('data-tags') || '0'),
      });
    });
  });

  // Article subscribe form — foil card incentive
  const artSubForm = document.getElementById('article-subscribe-form') as HTMLFormElement;
  const artSubStatus = document.getElementById('article-subscribe-status')!;
  const artSubBlock = document.getElementById('article-subscribe')!;

  if (localStorage.getItem('bz-subscribed')) {
    artSubBlock.innerHTML = '<p style="font-family:var(--font-body);font-size:0.9375rem;color:#22c55e;margin:0;text-align:center">You\'re in! Your foil card is on the way.</p>';
  } else {
    artSubForm?.addEventListener('submit', (e) => {
      e.preventDefault();
      const email = (document.getElementById('article-subscribe-email') as HTMLInputElement).value;
      const btn = document.getElementById('article-subscribe-btn') as HTMLButtonElement;
      btn.disabled = true;
      btn.textContent = '...';

      (window as any).gtag?.('event', 'subscribe', {
        email_domain: email.split('@')[1],
        location: 'article',
        incentive: 'foil-card',
      });

      fetch('/api/subscribe', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'article:' + slug, incentive: 'foil-card' })
      }).then((r) => {
        if (r.ok) {
          localStorage.setItem('bz-subscribed', email);
          artSubBlock.innerHTML = '<p style="font-family:var(--font-body);font-size:0.9375rem;color:#22c55e;margin:0;text-align:center">You\'re in! Your foil card is on the way.</p>';
        } else { throw new Error(); }
      }).catch(() => {
        artSubStatus.textContent = 'Something went wrong. Try again.';
        artSubStatus.style.color = '#ef4444';
        btn.disabled = false;
        btn.textContent = 'Claim my card';
      });
    });
  }
</script>
