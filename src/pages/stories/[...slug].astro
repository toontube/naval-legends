---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navigation from '../../components/Navigation.astro';
import Footer from '../../components/Footer.astro';
import SEOHead from '../../components/SEOHead.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const stories = await getCollection('stories');
  return stories.map((story) => ({
    params: { slug: story.data.slug },
    props: { story },
  }));
}

const { story } = Astro.props;
const { Content } = await render(story);

// Get other stories for "Read next"
const allStories = await getCollection('stories');
const otherStories = allStories
  .filter((s) => s.data.slug !== story.data.slug)
  .slice(0, 3);

const dateStr = story.data.date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout>
  <SEOHead
    slot="head"
    title={`${story.data.title} | Naval Legends`}
    description={story.data.summary}
    image={story.data.image}
    type="article"
  />

  <Navigation active="stories" showThemeToggle />

  <main class="article-page">
    <a href="/" class="article-back">&larr; Back to Daily</a>

    {story.data.image && (
      <figure class="article-hero">
        <img src={story.data.image} alt={story.data.title} />
      </figure>
    )}

    <header class="article-header">
      <h1 class="article-title">{story.data.title}</h1>
      <div class="article-meta">
        <time datetime={story.data.date.toISOString().split('T')[0]}>{dateStr}</time>
        <span>{story.data.readingTime} min read</span>
      </div>
    </header>

    <article class="prose" id="article-body">
      <Content />
    </article>

    <div class="article-tags">
      {story.data.tags.map((tag: string) => (
        <span class="article-tag">{tag}</span>
      ))}
    </div>

    {otherStories.length > 0 && (
      <section class="read-next">
        <h2 class="read-next-title">Read next</h2>
        <div class="read-next-grid">
          {otherStories.map((s) => (
            <a href={`/stories/${s.data.slug}`} class="read-next-card">
              <h3>{s.data.title}</h3>
              <p>{s.data.summary}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="article-cta">
      <a href="/" class="card-btn">&larr; Back to Daily</a>
    </div>
  </main>

  <Footer />
</BaseLayout>

<style>
  .article-page {
    padding-top: calc(var(--nav-height) + 2rem);
    padding-bottom: 3rem;
    max-width: 720px;
    margin: 0 auto;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }

  .article-back {
    display: inline-block;
    font-size: 0.875rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    transition: color 0.2s;
  }

  .article-back:hover {
    color: var(--text-primary);
  }

  .article-hero {
    margin: 0 -1.25rem 2rem;
    border-radius: 0;
    overflow: hidden;
    max-height: 400px;
  }

  @media (min-width: 640px) {
    .article-hero {
      margin: 0 0 2rem;
      border-radius: 8px;
    }
  }

  .article-hero img {
    width: 100%;
    height: 100%;
    max-height: 400px;
    object-fit: cover;
  }

  .article-header {
    margin-bottom: 2.5rem;
  }

  .article-title {
    font-size: clamp(1.75rem, 5vw, 2.5rem);
    line-height: 1.2;
    margin-bottom: 1rem;
  }

  .article-meta {
    display: flex;
    gap: 1rem;
    font-size: 0.875rem;
    color: var(--text-muted);
  }

  .article-meta span::before {
    content: '·';
    margin-right: 1rem;
  }

  .article-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .article-tag {
    font-size: 0.75rem;
    color: var(--text-muted);
    background: var(--bg-surface);
    padding: 0.25rem 0.625rem;
    border-radius: 4px;
    text-transform: lowercase;
  }

  .read-next {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--border);
  }

  .read-next-title {
    font-size: 1.25rem;
    margin-bottom: 1.25rem;
  }

  .read-next-grid {
    display: grid;
    gap: 1rem;
  }

  .read-next-card {
    display: block;
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 1.25rem;
    transition: border-color 0.2s;
  }

  .read-next-card:hover {
    border-color: var(--text-muted);
  }

  .read-next-card h3 {
    font-size: 1rem;
    margin-bottom: 0.375rem;
    line-height: 1.3;
  }

  .read-next-card p {
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.4;
  }

  .article-cta {
    margin-top: 2rem;
    text-align: center;
  }

  .article-cta .card-btn {
    display: inline-block;
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary);
    border: 1px solid var(--border);
    padding: 0.625rem 1.5rem;
    border-radius: 100px;
    transition: all 0.2s;
    text-decoration: none;
  }

  .article-cta .card-btn:hover {
    border-color: var(--text-muted);
  }
</style>

<script>
  // Pretext CLS prevention — measure article text after fonts load
  async function measureArticle() {
    try {
      const { prepare, layout } = await import('@chenglou/pretext');
      await document.fonts.ready;
      const el = document.getElementById('article-body');
      if (!el) return;
      const text = el.textContent || '';
      const prepared = prepare(text, '18px Lora');
      const { height } = layout(prepared, el.offsetWidth, 31.5);
      el.style.minHeight = `${height}px`;
    } catch {
      // Pretext is optional — degrade gracefully
    }
  }
  measureArticle();
</script>
