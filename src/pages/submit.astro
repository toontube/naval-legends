---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navigation from '../components/Navigation.astro';
import Footer from '../components/Footer.astro';
import SEOHead from '../components/SEOHead.astro';
---

<BaseLayout>
  <SEOHead
    slot="head"
    title="Submit a Story | Bravo Zulu"
    description="Know a wild naval history story? Send it to us. If we publish it, you get credited."
  />

  <Navigation showThemeToggle />

  <main class="submit-page">
    <h1>Got a good one?</h1>
    <p class="submit-intro">
      We're always looking for stories. A ship with a ridiculous backstory,
      a battle that reads like fiction, some detail you can't believe is real.
      If we publish it, you get credited.
    </p>

    <form class="submit-form" id="submit-form">
      <div class="form-group">
        <label for="name">Your name <span class="optional">(optional)</span></label>
        <input type="text" id="name" name="name" placeholder="For credit if we publish it" />
      </div>

      <div class="form-group">
        <label for="email">Email <span class="optional">(optional)</span></label>
        <input type="email" id="email" name="email" placeholder="In case we have questions" />
      </div>

      <div class="form-group">
        <label for="subject">Ship or event <span class="required">*</span></label>
        <input type="text" id="subject" name="subject" placeholder="e.g. HMS Campbeltown, Battle of Surigao Strait" required />
      </div>

      <div class="form-group">
        <label for="hook">What's the craziest part? <span class="required">*</span></label>
        <input type="text" id="hook" name="hook" placeholder="e.g. They disguised a destroyer as a German ship, packed it with explosives, and rammed it into a dock." required />
      </div>

      <div class="form-group">
        <label for="story">What happened? <span class="required">*</span></label>
        <textarea id="story" name="story" rows="8" placeholder="Tell it however you want. Bullet points, paragraphs, a bunch of links. Whatever you've got." required></textarea>
      </div>

      <div class="form-group">
        <label for="sources">Where'd you find it? <span class="optional">(optional)</span></label>
        <textarea id="sources" name="sources" rows="3" placeholder="Wikipedia, a book, a Reddit thread, a museum plaque. Anything helps."></textarea>
      </div>

      <button type="submit" class="submit-btn" id="submit-btn">
        Send it
      </button>

      <div class="submit-status" id="submit-status"></div>
    </form>
  </main>

  <Footer />
</BaseLayout>

<style>
  .submit-page {
    padding-top: calc(var(--nav-height) + var(--banner-offset) + 2rem);
    padding-bottom: 3rem;
    max-width: 600px;
    margin: 0 auto;
    padding-left: 1.25rem;
    padding-right: 1.25rem;
  }

  .submit-page h1 {
    font-size: 2rem;
    margin-bottom: 1rem;
  }

  .submit-intro {
    font-family: var(--font-body);
    font-size: 1.0625rem;
    line-height: 1.7;
    color: var(--text-secondary);
    margin-bottom: 2.5rem;
  }

  .submit-form {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .form-group label {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-primary);
  }

  .optional {
    color: var(--text-muted);
    font-weight: 400;
  }

  .required {
    color: #ef4444;
  }

  .form-group input,
  .form-group textarea {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    color: var(--text-primary);
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 0.75rem 1rem;
    transition: border-color 0.2s;
    resize: vertical;
  }

  .form-group input::placeholder,
  .form-group textarea::placeholder {
    color: var(--text-muted);
    font-size: 0.875rem;
  }

  .form-group input:focus,
  .form-group textarea:focus {
    outline: none;
    border-color: var(--accent);
  }

  .submit-btn {
    font-family: var(--font-ui);
    font-size: 0.9375rem;
    font-weight: 500;
    color: #fff;
    background: var(--accent);
    border: none;
    border-radius: 8px;
    padding: 0.875rem 1.5rem;
    transition: opacity 0.2s;
    margin-top: 0.5rem;
  }

  .submit-btn:hover {
    opacity: 0.9;
  }

  .submit-btn:disabled {
    opacity: 0.5;
    cursor: not-allowed;
  }

  .submit-status {
    font-family: var(--font-ui);
    font-size: 0.875rem;
    text-align: center;
    min-height: 1.5rem;
  }

  .submit-status.success {
    color: #22c55e;
  }

  .submit-status.error {
    color: #ef4444;
  }
</style>

<script is:inline>
  var form = document.getElementById('submit-form');
  var btn = document.getElementById('submit-btn');
  var status = document.getElementById('submit-status');

  form.addEventListener('submit', function(e) {
    e.preventDefault();

    var data = Object.fromEntries(new FormData(form));
    var gtag = window.gtag || function(){};
    gtag('event', 'submit_story', { subject: data.subject });

    var subject = encodeURIComponent('BZ Story: ' + data.subject);
    var body = encodeURIComponent(
      'From: ' + (data.name || 'Anonymous') +
      '\nEmail: ' + (data.email || 'not provided') +
      '\n\nThe craziest part:\n' + data.hook +
      '\n\nFull story:\n' + data.story +
      '\n\nSources:\n' + (data.sources || 'none')
    );

    window.location.href = 'mailto:max@mozuma.co?subject=' + subject + '&body=' + body;

    status.textContent = 'Opening your email app. Hit send and we\'ll take it from there.';
    status.className = 'submit-status success';
  });
</script>
