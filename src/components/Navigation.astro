---
interface Props {
  active?: 'daily' | 'stories';
  showThemeToggle?: boolean;
}

const { active = 'daily', showThemeToggle = false } = Astro.props;
---

<nav class="nav">
  <a href="/" class="nav-brand">Bravo Zulu</a>
  <div class="nav-right">
    <div class="nav-tabs">
      <a href="/" class:list={['nav-tab', { active: active === 'daily' }]}>Daily</a>
      <a href="/stories" class:list={['nav-tab', { active: active === 'stories' }]}>Stories</a>
    </div>
    {showThemeToggle && (
      <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
        <span class="theme-icon-dark">&#9790;</span>
        <span class="theme-icon-light">&#9788;</span>
      </button>
    )}
  </div>
</nav>

{showThemeToggle && (
  <script is:inline>
    document.getElementById('theme-toggle')?.addEventListener('click', () => {
      const current = document.documentElement.getAttribute('data-theme');
      const next = current === 'light' ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', next);
      localStorage.setItem('nl-theme', next);
      window.gtag?.('event', 'toggle_theme', { theme: next });
    });
  </script>
)}


<style>
  .nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--nav-height);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 1.25rem;
    background: rgba(10, 14, 23, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    z-index: 100;
  }

  :global([data-theme="light"]) .nav {
    background: rgba(250, 250, 249, 0.85);
    border-bottom-color: rgba(0, 0, 0, 0.06);
  }

  .nav-brand {
    font-family: var(--font-display);
    font-size: 1.125rem;
    font-weight: 700;
    letter-spacing: -0.01em;
    white-space: nowrap;
    flex-shrink: 0;
  }

  @media (max-width: 400px) {
    .nav-brand {
      font-size: 0.9375rem;
    }
  }

  .nav-right {
    display: flex;
    align-items: center;
    gap: 1.25rem;
  }

  .nav-tabs {
    display: flex;
    gap: 1.5rem;
  }

  @media (max-width: 400px) {
    .nav-tabs {
      gap: 0.875rem;
    }
  }

  .theme-toggle {
    font-size: 1.125rem;
    color: var(--text-muted);
    transition: color 0.2s;
    padding: 0.25rem;
    line-height: 1;
  }

  .theme-toggle:hover {
    color: var(--text-primary);
  }

  .theme-icon-light {
    display: none;
  }

  :global([data-theme="light"]) .theme-icon-dark {
    display: none;
  }

  :global([data-theme="light"]) .theme-icon-light {
    display: inline;
  }

  .nav-tab {
    font-size: 0.875rem;
    font-weight: 500;
    color: var(--text-muted);
    transition: color 0.2s;
    padding: 0.25rem 0;
  }

  .nav-tab:hover {
    color: var(--text-primary);
  }

  .nav-tab.active {
    color: var(--text-primary);
    border-bottom: 2px solid var(--text-primary);
  }

  :global(.ks-banner-visible) .nav {
    top: var(--ks-banner-height);
  }

</style>
