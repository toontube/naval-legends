---
const ksUrl = 'https://www.kickstarter.com/projects/mozuma/naval-legends-cruisers?ref=bz-banner';
---

<div class="ks-banner" id="ks-banner">
  <div class="ks-banner-inner">
    <p class="ks-banner-text">
      <strong>Naval Legends: Cruisers</strong> is live on Kickstarter.
      <a href={ksUrl} target="_blank" rel="noopener" class="ks-banner-link" id="ks-banner-link">
        Back the project &rarr;
      </a>
    </p>
    <button class="ks-banner-close" id="ks-banner-close" aria-label="Dismiss">&times;</button>
  </div>
</div>

<script is:inline>
  (function() {
    var banner = document.getElementById('ks-banner');
    if (localStorage.getItem('bz-ks-dismissed')) {
      banner.style.display = 'none';
    } else {
      document.documentElement.classList.add('ks-banner-visible');
    }

    document.getElementById('ks-banner-close').addEventListener('click', function() {
      banner.style.display = 'none';
      document.documentElement.classList.remove('ks-banner-visible');
      localStorage.setItem('bz-ks-dismissed', '1');
      var gtag = window.gtag || function(){};
      gtag('event', 'dismiss_ks_banner');
    });

    document.getElementById('ks-banner-link').addEventListener('click', function() {
      var gtag = window.gtag || function(){};
      gtag('event', 'click_ks_banner', { location: 'top_banner' });
    });
  })();
</script>

<style>
  .ks-banner {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    height: var(--ks-banner-height, 36px);
    background: var(--accent-dim);
    border-bottom: 1px solid rgba(59, 130, 246, 0.2);
    z-index: 101;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ks-banner-inner {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0 1rem;
    width: 100%;
    max-width: 900px;
    justify-content: center;
  }

  .ks-banner-text {
    font-family: var(--font-ui);
    font-size: 0.8125rem;
    color: var(--text-primary);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .ks-banner-text strong {
    font-weight: 600;
  }

  .ks-banner-link {
    color: var(--accent);
    font-weight: 600;
    text-decoration: none;
    margin-left: 0.25rem;
  }

  .ks-banner-link:hover {
    text-decoration: underline;
  }

  .ks-banner-close {
    font-size: 1.125rem;
    color: var(--text-muted);
    background: none;
    border: none;
    padding: 0.125rem 0.375rem;
    line-height: 1;
    flex-shrink: 0;
    transition: color 0.2s;
  }

  .ks-banner-close:hover {
    color: var(--text-primary);
  }

  @media (max-width: 480px) {
    .ks-banner-text {
      font-size: 0.75rem;
    }
  }
</style>
